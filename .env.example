# NiFi connection (used by nifipilot)
NIFI_URL=https://localhost:8443
NIFI_USERNAME=admin
NIFI_PASSWORD=your-password-here
NIFI_VERIFY_SSL=false
MCP_MODE=full

# MCP server URL
MCP_URL=http://localhost:8000/sse

# LLM provider — uncomment one block and set the matching API key

# Anthropic
LITELLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# OpenAI
# LITELLM_MODEL=gpt-4o
# OPENAI_API_KEY=

# Google
# LITELLM_MODEL=gemini/gemini-pro
# GEMINI_API_KEY=

# Ollama (local, free)
# LITELLM_MODEL=ollama/llama3
# No API key needed
